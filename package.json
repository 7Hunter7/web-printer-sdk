{
  "name": "web-printer-sdk",
  "version": "1.0.3",
  "description": "Профессиональный пакет SDK для подключения принтеров к веб-приложениям. Поддерживает Wi-Fi, Bluetooth, USB и термопринтеры с ESC/POS и ZPL командами.",
  "main": "src/index.js",
  "module": "src/index.js",
  "browser": "src/index.js",
  "types": "index.d.ts",
  "files": [
    "src",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js",
      "types": "./index.d.ts"
    },
    "./zpl": {
      "import": "./src/utils/zpl.js",
      "require": "./src/utils/zpl.js"
    },
    "./escpos": {
      "import": "./src/utils/escpos.js",
      "require": "./src/utils/escpos.js"
    },
    "./imageProcessor": {
      "import": "./src/utils/imageProcessor.js",
      "require": "./src/utils/imageProcessor.js"
    },
    "./vue": {
      "import": "./src/vue/printerMixin.js",
      "require": "./src/vue/printerMixin.js"
    }
  },
  "scripts": {
    "test": "echo \"No tests in production\" && exit 0"
  },
  "keywords": [
    "printer",
    "escpos",
    "zpl",
    "thermal-printer",
    "bluetooth-printer",
    "usb-printer",
    "wifi-printer",
    "receipt-printer",
    "web-printing",
    "vue-printer",
    "vue",
    "vue2",
    "vue3"
  ],
  "dependencies": {
    "iconv-lite": "^0.7.2"
  },
  "optionalDependencies": {
    "serialport": "^13.0.0",
    "usb": "^2.17.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "peerDependencies": {
    "vue": "^2.6.0 || ^3.0.0"
  },
  "author": {
    "name": "Ivan Kalugin",
    "email": "i.am.hunter.777.ih@gmail.com",
    "url": "https://github.com/7Hunter7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7Hunter7/web-printer-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/7Hunter7/web-printer-sdk/issues"
  },
  "homepage": "https://github.com/7Hunter7/web-printer-sdk#readme",
  "engines": {
    "node": ">=12.0.0"
  }
}
